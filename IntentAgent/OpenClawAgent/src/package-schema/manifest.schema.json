{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Package Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "workflow",
    "promptModulesDir",
    "systemPromptFile",
    "rules",
    "validators",
    "toolBindings"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "minLength": 1 },
    "promptModulesDir": { "type": "string", "minLength": 1 },
    "systemPromptFile": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "object",
      "required": ["classification", "context"],
      "properties": {
        "classification": { "type": "string", "minLength": 1 },
        "context": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "validators": { "type": "string", "minLength": 1 },
    "toolBindings": { "type": "string", "minLength": 1 },
    "postprocessors": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
