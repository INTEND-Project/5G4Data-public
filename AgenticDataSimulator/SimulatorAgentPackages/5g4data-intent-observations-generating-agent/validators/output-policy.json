{
  "forbiddenPhrases": [
    "i will proceed",
    "please hold on",
    "now i will create",
    "TODO",
    "<condition-id>",
    "_:obs"
  ],
  "requiredTokens": [
    "@prefix met:",
    "met:Observation",
    "met:observedMetric",
    "met:observedValue",
