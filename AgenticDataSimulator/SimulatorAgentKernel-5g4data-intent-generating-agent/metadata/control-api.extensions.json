{
  "paths": {
    "/v1/control/intent-generation/preview": {
      "post": {
        "operationId": "previewIntentGeneration",
        "summary": "Preview generation directives without persisting changes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": { "type": "string" },
                  "strictValidation": { "type": "boolean" }
                },
                "required": ["prompt"]
              }
            }
          }
        },
        "responses": {
          "501": { "description": "Extension declared by package; route not implemented in kernel runtime." }
        }
      }
    }
  }
}
