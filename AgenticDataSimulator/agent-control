#!/usr/bin/env bash
# Control OpenClaw simulator agents (intent generation + observations).
#
#   agent-control start    Load or start agent containers (reload clone when package or kernel changed).
#   agent-control stop     Stop and remove agent containers.
#   agent-control restart  Create missing agents, reload when package/kernel changed, or rebuild clone sources.
#   agent-control reload   Stop agents, remove all clones, package load from current sources (preserves API keys).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KERNEL="$ROOT/SimulatorAgentKernel"
KERNEL_MISTRAL_SMALL4="$ROOT/SimulatorAgentKernel-mistral.small4"
PACKAGES="$ROOT/SimulatorAgentPackages"
MISTRAL_SMALL4_PACKAGE="5g4data-intent-mistral-small4-generating-agent"

# Format: package_dir|port|agent_card_name
# Clone directory: agents/<package_dir>/ for all kernel clones.
# agent_card_name: A2A registry / AGENT_API_KEYS key (from package metadata).
CORE_AGENTS=(
  "5g4data-intent-generating-agent|3011|5g4data-intent-generating-agent"
  "5g4data-intent-observations-generating-agent|3012|5g4data-intent-observation-generating-agent"
  "${MISTRAL_SMALL4_PACKAGE}|3013|5g4data-intent-mistral-small4-generating-agent"
)

ALL_AGENTS=("${CORE_AGENTS[@]}")

# Paths copied from SimulatorAgentPackages into each clone (see packageCloneDeployer.ts).
DEPLOY_REL_PATHS=(
  manifest.json
  workflow.dsl.json
  compatibility.json
  checksums.txt
  rules
  validators
  tools
  prompts
  prompt_modules
  skills
  dependencies
  schemas
  validation
  examples
  tests
  mappings
  metadata
  templates
)

# Baseline kernel paths copied into each clone (see agentCloneManager.ts).
# Exclude package.json / package-lock.json: the clone merges package deps on load and
# would otherwise look newer than the baseline kernel without a real kernel change.
KERNEL_REL_PATHS=(
  src
  scripts
  Dockerfile
  .dockerignore
  tsconfig.json
)

usage() {
  cat <<EOF
Usage: agent-control {start|stop|restart|reload} [package-name]

Run from the AgenticDataSimulator directory as ./agent-control,
or add AgenticDataSimulator/bin to PATH (see README.md).

  start    Create clones if missing; when package or SimulatorAgentKernel sources changed,
           remove existing clone(s), package load, and start containers.
  stop     Stop and remove running agent containers.
  restart  Like start for missing or package/kernel-changed agents; otherwise rebuild when clone sources changed.
  reload   Stop agents, remove clone directories, package load from current sources,
           and wait for health. Preserves AGENT_API_KEYS from SimulatorController/.env when present.

  package-name  Optional. Limit the command to one SimulatorAgentPackages directory name
                (e.g. 5g4data-intent-mistral-small4-generating-agent). When omitted, all
                agents listed below are affected.

Agents (package directory → port):
  - 5g4data-intent-generating-agent (3011)
  - 5g4data-intent-observations-generating-agent (3012)
  - 5g4data-intent-mistral-small4-generating-agent (3013)

Examples:
  ./agent-control reload
  ./agent-control reload 5g4data-intent-generating-agent
  ./agent-control stop 5g4data-intent-mistral-small4-generating-agent

Agents start with --debug (file logs under each clone's logs/ directory).
EOF
}

resolve_agents() {
  local filter="${1:-}"
  SELECTED_AGENTS=()

  if [[ -z "$filter" ]]; then
    SELECTED_AGENTS=("${ALL_AGENTS[@]}")
    return 0
  fi

  local entry package
  for entry in "${ALL_AGENTS[@]}"; do
    IFS='|' read -r package _ agent_card <<<"$entry"
    if [[ "$package" == "$filter" ]]; then
      SELECTED_AGENTS+=("$entry")
      return 0
    fi
  done

  echo "ERROR: unknown package-name '${filter}'." >&2
  echo "Known package directories:" >&2
  for entry in "${ALL_AGENTS[@]}"; do
    IFS='|' read -r package port agent_card <<<"$entry"
    echo "  - ${package} (port ${port}, agent card: ${agent_card})" >&2
  done
  return 1
}

print_selected_health_urls() {
  local entry package port agent_card
  for entry in "${SELECTED_AGENTS[@]}"; do
    IFS='|' read -r package port agent_card <<<"$entry"
    echo "  ${package} (${agent_card}): http://127.0.0.1:${port}/health"
  done
}

wire_extra_agent_lab() {
  local package="$1"
  case "$package" in
    "$MISTRAL_SMALL4_PACKAGE")
      if [[ -x "${ROOT}/scripts/wire-intent-agent-e1-lab.sh" ]]; then
        "${ROOT}/scripts/wire-intent-agent-e1-lab.sh"
      fi
      ;;
  esac
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "ERROR: docker is not installed or not on PATH" >&2
    exit 1
  fi
  if ! docker compose version >/dev/null 2>&1; then
    echo "ERROR: docker compose is not available" >&2
    exit 1
  fi
}

kernel_dir_for_package() {
  local package="$1"
  if [[ "$package" == "$MISTRAL_SMALL4_PACKAGE" ]]; then
    printf '%s\n' "$KERNEL_MISTRAL_SMALL4"
  else
    printf '%s\n' "$KERNEL"
  fi
}

clone_base_dir() {
  local package="$1"
  printf '%s/agents/%s\n' "$ROOT" "$package"
}

clone_base_candidates() {
  local package="$1"
  clone_base_dir "$package"
}

find_versioned_clone_dir() {
  local base="$1"

  if [[ -d "$base" ]]; then
    printf '%s\n' "$base"
    return 0
  fi

  local latest=""
  local version=2
  while [[ -d "${base}-v${version}" ]]; do
    latest="${base}-v${version}"
    version=$((version + 1))
  done
  if [[ -n "$latest" ]]; then
    printf '%s\n' "$latest"
  fi
}

find_clone_dir() {
  local package="$1"
  local agent_card="${2:-}"
  local base found

  while IFS= read -r base; do
    [[ -n "$base" ]] || continue
    found="$(find_versioned_clone_dir "$base" || true)"
    if [[ -n "$found" ]]; then
      printf '%s\n' "$found"
      return 0
    fi
  done < <(clone_base_candidates "$package" "$agent_card")
}

find_newest_file_epoch() {
  local path="$1"
  find "$path" \
    \( -path '*/node_modules/*' -o -path '*/logs/*' -o -path '*/dist/*' -o -path '*/.git/*' \) -prune \
    -o -type f -printf '%T@\n' 2>/dev/null \
    | sort -n \
    | tail -1 \
    | cut -d. -f1
}

newest_epoch_under_rel_paths() {
  local root="$1"
  shift
  local max=0
  local rel path epoch

  for rel in "$@"; do
    path="$root/$rel"
    [[ -e "$path" ]] || continue
    epoch="$(find_newest_file_epoch "$path" || true)"
    if [[ -n "$epoch" && "$epoch" -gt "$max" ]]; then
      max="$epoch"
    fi
  done

  if (( max > 0 )); then
    printf '%s\n' "$max"
  fi
}

newest_epoch_under_deploy_paths() {
  newest_epoch_under_rel_paths "$1" "${DEPLOY_REL_PATHS[@]}"
}

kernel_newest_epoch() {
  newest_epoch_under_rel_paths "$KERNEL" "${KERNEL_REL_PATHS[@]}"
}

clone_kernel_newest_epoch() {
  local clone_dir="$1"
  newest_epoch_under_rel_paths "$clone_dir" "${KERNEL_REL_PATHS[@]}"
}

needs_package_reload() {
  local package_dir="$1"
  local clone_dir="${2:-}"

  [[ -d "$package_dir" ]] || return 1
  [[ -n "$clone_dir" && -d "$clone_dir" ]] || return 1

  local package_epoch clone_epoch
  package_epoch="$(newest_epoch_under_deploy_paths "$package_dir" || true)"
  clone_epoch="$(newest_epoch_under_deploy_paths "$clone_dir" || true)"

  [[ -n "$package_epoch" ]] || return 1
  [[ -n "$clone_epoch" ]] || return 0

  (( package_epoch > clone_epoch ))
}

kernel_newest_epoch_for_dir() {
  local kernel_root="$1"
  newest_epoch_under_rel_paths "$kernel_root" "${KERNEL_REL_PATHS[@]}"
}

needs_kernel_reload() {
  local clone_dir="${1:-}"
  local package="${2:-}"

  local kernel_root
  kernel_root="$(kernel_dir_for_package "$package")"

  [[ -d "$kernel_root" ]] || return 1
  [[ -n "$clone_dir" && -d "$clone_dir" ]] || return 1

  local kernel_epoch clone_epoch
  kernel_epoch="$(kernel_newest_epoch_for_dir "$kernel_root" || true)"
  clone_epoch="$(clone_kernel_newest_epoch "$clone_dir" || true)"

  [[ -n "$kernel_epoch" ]] || return 1
  [[ -n "$clone_epoch" ]] || return 0

  (( kernel_epoch > clone_epoch ))
}

needs_clone_reload() {
  local package="$1"
  local clone_dir="${2:-}"
  local package_dir="$PACKAGES/$package"

  needs_package_reload "$package_dir" "$clone_dir" && return 0
  needs_kernel_reload "$clone_dir" "$package" && return 0
  return 1
}

remove_clone_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0

  if [[ -f "$dir/docker-compose.yml" ]]; then
    echo "    Stopping container in ${dir} ..."
    (cd "$dir" && docker compose down --remove-orphans) || true
  fi

  echo "    Removing ${dir} ..."
  rm -rf "$dir" 2>/dev/null || true
  if [[ ! -d "$dir" ]]; then
    return 0
  fi

  # Container bind-mount writes under logs/ are often root-owned on the host.
  echo "    Clearing root-owned clone files via Docker ..."
  local parent name
  parent="$(cd "$(dirname "$dir")" && pwd)"
  name="$(basename "$dir")"
  if docker run --rm -v "${parent}:/parent" alpine:3.20 rm -rf "/parent/${name}"; then
    return 0
  fi

  echo "ERROR: could not remove ${dir} (permission denied)." >&2
  return 1
}

remove_all_clones_for_package() {
  local package="$1"
  local agent_card="${2:-}"
  local -a dirs=()
  local base dir version=2

  while IFS= read -r base; do
    [[ -n "$base" ]] || continue
    [[ -d "$base" ]] && dirs+=("$base")
    version=2
    while [[ -d "${base}-v${version}" ]]; do
      dirs+=("${base}-v${version}")
      version=$((version + 1))
    done
  done < <(clone_base_candidates "$package" "$agent_card")

  for dir in "${dirs[@]}"; do
    remove_clone_dir "$dir" || return 1
  done
}

CONTROLLER_ENV="${ROOT}/SimulatorController/.env"

read_preserved_agent_api_key() {
  local agent_name="$1"
  python3 - "$CONTROLLER_ENV" "$agent_name" <<'PY'
import json
import re
import sys

path, name = sys.argv[1], sys.argv[2]
try:
    text = open(path, encoding="utf-8").read()
except OSError:
    sys.exit(0)

match = re.search(r"^AGENT_API_KEYS=(.*)$", text, re.MULTILINE)
if not match:
    sys.exit(0)

raw = match.group(1).strip().strip("'\"")
try:
    data = json.loads(raw)
except json.JSONDecodeError:
    sys.exit(0)

key = (data.get(name) or "").strip()
if key:
    print(key)
PY
}

load_agent_package() {
  local package="$1"
  local label="$2"
  local agent_card_name="${3:-}"

  local kernel_dir
  kernel_dir="$(kernel_dir_for_package "$package")"

  echo "==> Loading ${label} from package ${package} (kernel: $(basename "$kernel_dir"))"
  if [[ ! -d "$kernel_dir/node_modules" ]]; then
    echo "    Installing kernel dependencies ..."
    (cd "$kernel_dir" && npm install)
  fi
  local preserve=""
  if [[ -n "$agent_card_name" ]]; then
    preserve="$(read_preserved_agent_api_key "$agent_card_name" || true)"
  fi
  if [[ -n "$preserve" ]]; then
    echo "    Preserving AGENT_API_KEY for ${agent_card_name} from SimulatorController/.env"
    (cd "$kernel_dir" && PRESERVE_AGENT_API_KEY="$preserve" npx tsx src/index.ts package load "$PACKAGES/$package")
  else
    (cd "$kernel_dir" && npx tsx src/index.ts package load "$PACKAGES/$package")
  fi
}

compose_image_created_epoch() {
  local clone_dir="$1"
  local image_id created
  image_id="$(cd "$clone_dir" && docker compose images -q agent 2>/dev/null | head -1)"
  if [[ -z "$image_id" ]]; then
    return 1
  fi
  created="$(docker inspect -f '{{.Created}}' "$image_id" 2>/dev/null || true)"
  if [[ -z "$created" ]]; then
    return 1
  fi
  date -d "$created" +%s 2>/dev/null || return 1
}

clone_newest_source_epoch() {
  local clone_dir="$1"
  find "$clone_dir" \
    \( -path "$clone_dir/node_modules" -o -path "$clone_dir/dist" -o -path "$clone_dir/logs" -o -path "$clone_dir/.git" \) -prune \
    -o -type f -printf '%T@\n' \
    | sort -n \
    | tail -1 \
    | cut -d. -f1
}

needs_image_build() {
  local clone_dir="$1"
  local image_epoch source_epoch

  if ! image_epoch="$(compose_image_created_epoch "$clone_dir")"; then
    return 0
  fi

  source_epoch="$(clone_newest_source_epoch "$clone_dir")"
  if [[ -z "$source_epoch" ]]; then
    return 1
  fi

  if (( source_epoch > image_epoch )); then
    return 0
  fi
  return 1
}

wait_for_health() {
  local port="$1"
  local label="$2"
  local url="http://127.0.0.1:${port}/health"
  echo "Waiting for ${label} at ${url} ..."
  for _ in $(seq 1 60); do
    if curl -sf "$url" >/dev/null 2>&1; then
      echo "OK: ${label} (${url})"
      return 0
    fi
    sleep 1
  done
  echo "ERROR: ${label} did not respond at ${url} within 60s" >&2
  return 1
}

start_agent() {
  local package="$1"
  local port="$2"
  local agent_card="$3"

  local package_dir="$PACKAGES/$package"
  local clone_dir
  clone_dir="$(find_clone_dir "$package" "$agent_card" || true)"

  if [[ -n "$clone_dir" ]] && needs_clone_reload "$package" "$clone_dir"; then
    if needs_kernel_reload "$clone_dir" "$package"; then
      echo "==> SimulatorAgentKernel changed; reloading ${package}"
    else
      echo "==> Package ${package} changed; reloading ${package}"
    fi
    remove_all_clones_for_package "$package" "$agent_card"
    clone_dir=""
  fi

  if [[ -z "$clone_dir" || ! -f "$clone_dir/docker-compose.yml" ]]; then
    load_agent_package "$package" "$package" "$agent_card"
    clone_dir="$(find_clone_dir "$package" "$agent_card" || true)"
    if [[ -z "$clone_dir" ]]; then
      echo "ERROR: clone directory not found after package load for ${package}" >&2
      exit 1
    fi
  else
    echo "==> Starting ${package} in ${clone_dir}"
    if needs_image_build "$clone_dir"; then
      echo "    Build required (sources newer than image or image missing)"
      (cd "$clone_dir" && docker compose build)
    else
      echo "    Image up to date; skipping build"
    fi
    (cd "$clone_dir" && docker compose up -d)
  fi

  wait_for_health "$port" "$package"
  wire_extra_agent_lab "$package"
  echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
  echo "Agent log files: ${clone_dir}/logs/"
  echo
}

restart_agent() {
  local package="$1"
  local port="$2"
  local agent_card="$3"

  local clone_dir
  clone_dir="$(find_clone_dir "$package" "$agent_card" || true)"

  if [[ -z "$clone_dir" || ! -f "$clone_dir/docker-compose.yml" ]]; then
    echo "==> ${package}: not created yet; loading from package ${package}"
    start_agent "$package" "$port" "$agent_card"
    return 0
  fi

  if needs_clone_reload "$package" "$clone_dir"; then
    if needs_kernel_reload "$clone_dir" "$package"; then
      echo "==> ${package}: SimulatorAgentKernel changed; reloading clone"
    else
      echo "==> ${package}: package ${package} changed; reloading clone"
    fi
    remove_all_clones_for_package "$package" "$agent_card"
    load_agent_package "$package" "$package" "$agent_card"
    clone_dir="$(find_clone_dir "$package" "$agent_card" || true)"
    if [[ -z "$clone_dir" ]]; then
      echo "ERROR: clone directory not found after package load for ${package}" >&2
      exit 1
    fi
    wait_for_health "$port" "$package"
    wire_extra_agent_lab "$package"
    echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
    echo "Agent log files: ${clone_dir}/logs/"
    echo
    return 0
  fi

  if ! needs_image_build "$clone_dir"; then
    echo "==> ${package}: image up to date; skipping restart"
    return 1
  fi

  echo "==> Rebuilding and restarting ${package} in ${clone_dir}"
  (cd "$clone_dir" && docker compose build)
  (cd "$clone_dir" && docker compose up -d --force-recreate)
  wait_for_health "$port" "$package"
  wire_extra_agent_lab "$package"
  echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
  echo "Agent log files: ${clone_dir}/logs/"
  echo
  return 0
}

stop_agent() {
  local package="$1"
  local agent_card="${2:-}"

  local clone_dir
  clone_dir="$(find_clone_dir "$package" "$agent_card" || true)"

  if [[ -z "$clone_dir" ]]; then
    echo "==> ${package}: no clone directory found; nothing to stop"
    return 0
  fi
  if [[ ! -f "$clone_dir/docker-compose.yml" ]]; then
    echo "==> ${package}: no docker-compose.yml in ${clone_dir}; nothing to stop"
    return 0
  fi

  echo "==> Stopping ${package} in ${clone_dir}"
  (cd "$clone_dir" && docker compose down)
}

cmd_start() {
  require_docker
  resolve_agents "${PACKAGE_FILTER:-}" || exit 1
  echo "Starting OpenClaw simulator agents from ${ROOT}"
  echo

  local entry package port agent_card
  for entry in "${SELECTED_AGENTS[@]}"; do
    IFS='|' read -r package port agent_card <<<"$entry"
    start_agent "$package" "$port" "$agent_card"
  done

  echo "Selected agent(s) are up."
  print_selected_health_urls
}

cmd_stop() {
  require_docker
  resolve_agents "${PACKAGE_FILTER:-}" || exit 1
  echo "Stopping OpenClaw simulator agents from ${ROOT}"
  echo

  local entry package agent_card
  for entry in "${SELECTED_AGENTS[@]}"; do
    IFS='|' read -r package _ agent_card <<<"$entry"
    stop_agent "$package" "$agent_card"
  done

  echo "Done."
}

cmd_restart() {
  require_docker
  resolve_agents "${PACKAGE_FILTER:-}" || exit 1
  echo "Checking OpenClaw simulator agents for package, kernel, or clone changes from ${ROOT}"
  echo

  local entry package port agent_card updated=0
  for entry in "${SELECTED_AGENTS[@]}"; do
    IFS='|' read -r package port agent_card <<<"$entry"
    if restart_agent "$package" "$port" "$agent_card"; then
      updated=$((updated + 1))
    fi
  done

  if (( updated == 0 )); then
    echo "No agents required creation or rebuild."
  else
    echo "Created or restarted ${updated} agent(s)."
    print_selected_health_urls
  fi
}

cmd_reload() {
  require_docker
  resolve_agents "${PACKAGE_FILTER:-}" || exit 1
  echo "Force-reloading OpenClaw simulator agents from ${ROOT}"
  echo "    AGENT_API_KEYS preserved from SimulatorController/.env when present."

  local entry package
  for entry in "${SELECTED_AGENTS[@]}"; do
    IFS='|' read -r package _ agent_card <<<"$entry"
    stop_agent "$package" "$agent_card"
  done
  echo

  for entry in "${SELECTED_AGENTS[@]}"; do
    IFS='|' read -r package port agent_card <<<"$entry"
    echo "==> Force reload: ${package}"
    remove_all_clones_for_package "$package" "$agent_card"
    load_agent_package "$package" "$package" "$agent_card"
    wait_for_health "$port" "$package"
    local clone_dir
    clone_dir="$(find_clone_dir "$package" "$agent_card" || true)"
    if [[ -n "$clone_dir" ]]; then
      echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
      echo "Agent log files: ${clone_dir}/logs/"
    fi
    wire_extra_agent_lab "$package"
    echo
  done

  echo "Selected agent(s) reloaded from current package and kernel sources."
  print_selected_health_urls
}

COMMAND="${1:-}"
PACKAGE_FILTER="${2:-}"

case "$COMMAND" in
  start) cmd_start ;;
  stop) cmd_stop ;;
  restart) cmd_restart ;;
  reload) cmd_reload ;;
  -h|--help|help) usage ;;
  *)
    usage >&2
    exit 1
    ;;
esac
