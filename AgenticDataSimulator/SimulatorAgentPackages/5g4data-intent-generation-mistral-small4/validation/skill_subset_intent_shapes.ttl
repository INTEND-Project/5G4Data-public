@prefix data5g: <http://5g4data.eu/5g4data#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix icm: <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix imo: <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .
@prefix log: <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix quan: <http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix set: <http://tio.models.tmforum.org/tio/v3.6.0/SetOperators/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix time: <http://tio.models.tmforum.org/tio/v3.8.0/TimeOntology/> .
@prefix fun: <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix ut: <http://tio.models.tmforum.org/tio/v3.6.0/Utility/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# SHACL profile for the 5G4Data SKILL.md subset used by StandalonePythonAgent.
# This profile is intentionally strict for generated intents:
# - allowed expectation classes only
# - network target and condition metric restrictions
# - deployment target/context restrictions
# - reporting expectation coverage for included targets

data5g:AllowedIntentMemberShape
    a sh:NodeShape ;
    sh:or (
        [ sh:class data5g:DeploymentExpectation ]
        [ sh:class data5g:NetworkExpectation ]
        [ sh:class data5g:CoordinationExpectation ]
        [ sh:class data5g:SustainabilityExpectation ]
        [ sh:class data5g:ExplanationExpectation ]
        [ sh:class icm:ReportingExpectation ]
        [ sh:class icm:ObservationReportingExpectation ]
    ) .

data5g:IntentShape
    a sh:NodeShape ;
    sh:targetClass icm:Intent ;
    sh:property [
        sh:path dct:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path imo:handler ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path imo:owner ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path log:allOf ;
        sh:minCount 1 ;
        sh:node data5g:AllowedIntentMemberShape
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "When deployment expectation is present, a reporting expectation targeting data5g:deployment must also be present in intent log:allOf." ;
        sh:select """
            SELECT $this
            WHERE {
              $this log:allOf ?de .
              ?de a data5g:DeploymentExpectation .
              FILTER NOT EXISTS {
                $this log:allOf ?re .
                { ?re a icm:ReportingExpectation } UNION { ?re a icm:ObservationReportingExpectation } .
                ?re icm:target data5g:deployment .
              }
            }
        """
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "When network expectation is present, a reporting expectation targeting data5g:network-slice must also be present in intent log:allOf." ;
        sh:select """
            SELECT $this
            WHERE {
              $this log:allOf ?ne .
              ?ne a data5g:NetworkExpectation .
              FILTER NOT EXISTS {
                $this log:allOf ?re .
                { ?re a icm:ReportingExpectation } UNION { ?re a icm:ObservationReportingExpectation } .
                ?re icm:target data5g:network-slice .
              }
            }
        """
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "When sustainability expectation is present, a reporting expectation targeting data5g:sustainability must also be present in intent log:allOf." ;
        sh:select """
            SELECT $this
            WHERE {
              $this log:allOf ?se .
              ?se a data5g:SustainabilityExpectation .
              FILTER NOT EXISTS {
                $this log:allOf ?re .
                { ?re a icm:ReportingExpectation } UNION { ?re a icm:ObservationReportingExpectation } .
                ?re icm:target data5g:sustainability .
              }
            }
        """
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "When coordination expectation is present, a reporting expectation targeting data5g:coordination-service must also be present in intent log:allOf." ;
        sh:select """
            SELECT $this
            WHERE {
              $this log:allOf ?ce .
              ?ce a data5g:CoordinationExpectation .
              FILTER NOT EXISTS {
                $this log:allOf ?re .
                { ?re a icm:ReportingExpectation } UNION { ?re a icm:ObservationReportingExpectation } .
                ?re icm:target <http://5g4data.eu/5g4data#coordination-service> .
              }
            }
        """
    ] .

data5g:DeploymentExpectationShape
    a sh:NodeShape ;
    sh:targetClass data5g:DeploymentExpectation ;
    sh:property [
        sh:path time:numericDuration ;
        sh:maxCount 0
    ] ;
    sh:property [
        sh:path time:unitType ;
        sh:maxCount 0
    ] ;
    sh:property [
        sh:path icm:target ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue data5g:deployment
    ] ;
    sh:property [
        sh:path log:allOf ;
        sh:minCount 1 ;
        sh:node data5g:DeploymentExpectationMemberShape
    ] .

data5g:DeploymentExpectationMemberShape
    a sh:NodeShape ;
    sh:or (
        [ sh:class icm:Condition ]
        [ sh:class icm:Context ]
    ) .

data5g:NetworkExpectationShape
    a sh:NodeShape ;
    sh:targetClass data5g:NetworkExpectation ;
    sh:property [
        sh:path icm:target ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue data5g:network-slice
    ] ;
    sh:property [
        sh:path log:allOf ;
        sh:minCount 2 ;
        sh:node data5g:NetworkExpectationMemberShape
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "NetworkExpectation must include at least one referenced condition using a bandwidth metric property (data5g:bandwidth_*)." ;
        sh:select """
            SELECT $this
            WHERE {
              FILTER NOT EXISTS {
                $this log:allOf ?cond .
                ?cond a icm:Condition ;
                      set:forAll ?fa .
                ?fa icm:valuesOfTargetProperty ?metric .
                FILTER(STRSTARTS(STR(?metric), "http://5g4data.eu/5g4data#bandwidth_"))
              }
            }
        """
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "NetworkExpectation must include at least one referenced condition using a latency metric property (data5g:latency_*)." ;
        sh:select """
            SELECT $this
            WHERE {
              FILTER NOT EXISTS {
                $this log:allOf ?cond .
                ?cond a icm:Condition ;
                      set:forAll ?fa .
                ?fa icm:valuesOfTargetProperty ?metric .
                FILTER(STRSTARTS(STR(?metric), "http://5g4data.eu/5g4data#latency_"))
              }
            }
        """
    ] .

data5g:NetworkExpectationMemberShape
    a sh:NodeShape ;
    sh:or (
        [ sh:class icm:Condition ]
        [ sh:class icm:Context ]
    ) .

data5g:SustainabilityExpectationShape
    a sh:NodeShape ;
    sh:targetClass data5g:SustainabilityExpectation ;
    sh:property [
        sh:path time:numericDuration ;
        sh:maxCount 0
    ] ;
    sh:property [
        sh:path time:unitType ;
        sh:maxCount 0
    ] .

data5g:ReportingExpectationTargetShape
    a sh:NodeShape ;
    sh:property [
        sh:path icm:target ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ( data5g:deployment data5g:network-slice data5g:llm-service data5g:coordination-service data5g:sustainability )
    ] .

data5g:ReportingExpectationShape
    a sh:NodeShape ;
    sh:targetClass icm:ReportingExpectation ;
    sh:node data5g:ReportingExpectationTargetShape .

data5g:ObservationReportingExpectationShape
    a sh:NodeShape ;
    sh:targetClass icm:ObservationReportingExpectation ;
    sh:node data5g:ReportingExpectationTargetShape .

data5g:CoordinationExpectationShape
    a sh:NodeShape ;
    sh:targetClass data5g:CoordinationExpectation ;
    sh:property [
        sh:path time:numericDuration ;
        sh:maxCount 0
    ] ;
    sh:property [
        sh:path time:unitType ;
        sh:maxCount 0
    ] ;
    sh:property [
        sh:path icm:target ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue data5g:coordination-service
    ] ;
    sh:property [
        sh:path ut:utility ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "CoordinationExpectation must reference at least one metric condition (icm:Condition with set:forAll) in log:allOf." ;
        sh:select """
            SELECT $this
            WHERE {
              FILTER NOT EXISTS {
                $this log:allOf ?co .
                ?co a icm:Condition ;
                    set:forAll ?fa .
                ?fa icm:valuesOfTargetProperty ?metric .
              }
            }
        """
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "CoordinationExpectation metric condition count must match linked utility function arityMax." ;
        sh:select """
            SELECT $this
            WHERE {
              $this a data5g:CoordinationExpectation ;
                    ut:utility ?uInfo .
              ?uInfo ut:function ?fn .
              ?fn fun:arityMax ?arity .
              {
                SELECT (COUNT(DISTINCT ?co) AS ?coCount)
                WHERE {
                  $this log:allOf ?co .
                  ?co a icm:Condition ;
                      set:forAll ?fa .
                }
              }
              FILTER(BOUND(?coCount) && ?coCount > 0 && ?coCount != ?arity)
            }
        """
    ] .

data5g:UtilityProfileShape
    a sh:NodeShape ;
    sh:targetClass ut:UtilityProfile ;
    sh:property [
        sh:path ut:minUtility ;
        sh:hasValue "0.0"^^xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ut:maxUtility ;
        sh:hasValue "1.0"^^xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

data5g:UtilityInformationShape
    a sh:NodeShape ;
    sh:targetClass ut:UtilityInformation ;
    sh:property [
        sh:path ut:function ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ut:withArguments ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ut:forMetric ;
        sh:minCount 1
    ] ;
    sh:property [
        sh:path ut:utilityProfile ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class ut:UtilityProfile
    ] .

data5g:CoordinationUtilityFunctionShape
    a sh:NodeShape ;
    sh:target [
        a sh:Target ;
        sh:sparql [
            sh:select """
                SELECT ?this WHERE {
                    ?this a fun:Function .
                    FILTER(
                        CONTAINS(STR(?this), "utilityFn_symmetric")
                        || CONTAINS(STR(?this), "utilityFn_weighted")
                        || REGEX(STR(?this), "UN[0-9a-f]{32}$", "i")
                    )
                }
            """
        ]
    ] ;
    sh:property [
        sh:path fun:arityMin ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path fun:arityMax ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path rdf:value ;
        sh:maxCount 1
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Coordination utility function fun:arityMin must equal fun:arityMax." ;
        sh:select """
            SELECT $this
            WHERE {
              $this fun:arityMin ?min ;
              $this fun:arityMax ?max .
              FILTER(?min != ?max)
            }
        """
    ] .

# Metric conditions (expectations, coordination via reused DE/SE COs) require set:forAll.
data5g:MetricConditionShape
    a sh:NodeShape ;
    sh:property [
        sh:path set:forAll ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ( set:forAll icm:valuesOfTargetProperty ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path ( set:forAll [ sh:alternativePath ( quan:smaller quan:larger quan:inRange ) ] ) ;
        sh:minCount 1
    ] .

# Coordination reporting anchors may be description-only (no set:forAll).
data5g:CoordinationAnchorConditionShape
    a sh:NodeShape ;
    sh:property [
        sh:path dct:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path set:forAll ;
        sh:maxCount 0
    ] .

data5g:ConditionShape
    a sh:NodeShape ;
    sh:targetClass icm:Condition ;
    sh:or (
        [ sh:node data5g:MetricConditionShape ]
        [ sh:node data5g:CoordinationAnchorConditionShape ]
    ) .

data5g:DeploymentContextShape
    a sh:NodeShape ;
    sh:targetClass icm:Context ;
    sh:property [
        sh:path data5g:DataCenter ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^EC_[0-9]+$" ;
        sh:message "data5g:DataCenter must be an infra KG edge cluster id (e.g. EC_31), not a human place name."
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "A context with deployment semantics must include exactly one data5g:DataCenter and one data5g:DeploymentDescriptor." ;
        sh:select """
            SELECT $this
            WHERE {
              $this data5g:DeploymentDescriptor ?dd .
              FILTER NOT EXISTS {
                $this data5g:DataCenter ?dc .
              }
            }
        """
    ] .

data5g:NetworkContextShape
    a sh:NodeShape ;
    sh:targetClass icm:Context ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "A context with appliesToRegion must also include appliesToCustomer." ;
        sh:select """
            SELECT $this
            WHERE {
              $this data5g:appliesToRegion ?region .
              FILTER NOT EXISTS { $this data5g:appliesToCustomer ?cust . }
            }
        """
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "data5g:appliesToRegion must point to a geo:Feature." ;
        sh:select """
            SELECT $this
            WHERE {
              $this data5g:appliesToRegion ?region .
              FILTER NOT EXISTS { ?region a geo:Feature . }
            }
        """
    ] .
