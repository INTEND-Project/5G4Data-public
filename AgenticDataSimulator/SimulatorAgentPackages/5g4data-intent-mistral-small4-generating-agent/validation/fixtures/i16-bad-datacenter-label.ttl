data5g:I_bad a icm:Intent ;
    dct:description "bad datacenter label" ;
    imo:handler "inServ" ;
    imo:owner "inChat" ;
    log:allOf data5g:DE1, data5g:RE1 .

data5g:DE1 a data5g:DeploymentExpectation ;
    icm:target data5g:deployment ;
    log:allOf data5g:CX1 .

data5g:CX1 a icm:Context ;
    data5g:DataCenter "Tromsø Data Center" ;
    data5g:DeploymentDescriptor "https://example/chart" .

data5g:RE1 a icm:ObservationReportingExpectation ;
    icm:target data5g:deployment .
