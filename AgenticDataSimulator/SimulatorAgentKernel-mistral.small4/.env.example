# Inbound A2A/API authentication (required in production)
AGENT_API_KEY=
AGENT_API_KEY_HEADER=X-Api-Key

# HTTP API server
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=3011

# A2A discovery
A2A_ENABLED=false
A2A_REGISTRY_BASE_URL=https://start5g-1.cs.uit.no/a2a-registry
A2A_AGENT_BASE_URL=http://localhost:3010
A2A_AGENT_CARD_PATH=/.well-known/agent-card.json
A2A_AUTO_REGISTER_ON_STARTUP=true

# LLM provider — Mistral Small 4 via OpenAI-compatible API
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=mistral-small-2603
OPENCLAW_MODEL=mistral-small-2603
OPENAI_BASE_URL=https://api.mistral.ai/v1
OPENAI_TEMPERATURE=0
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Workload catalogue and ontology grounding
WORKLOAD_CATALOG_BASE_URL=https://start5g-1.cs.uit.no/wchartmuseum
ONTOLOGY_ROOT=
EXAMPLE_INTENTS_ROOT=

# GraphDB HTTP Basic auth (required when GraphDB security is enabled)
GRAPHDB_USERNAME=telenor
GRAPHDB_PASSWORD=
# Intent / observation persistence (separate from infrastructure KG)
GRAPHDB_BASE_URL=http://host.docker.internal:7200/
GRAPHDB_REPOSITORY_ID=intents_and_intent_reports
# Infrastructure KG — edge-cluster locality lookups (GRAPHDB_INFRA_* only)
GRAPHDB_INFRA_REPOSITORY_ID=telenor-infrastructure-5g4data
GRAPHDB_INFRA_NAMED_GRAPH=http://intendproject.eu/telenor/infra
GRAPHDB_INFRA_ENDPOINT=http://host.docker.internal:7200/repositories/telenor-infrastructure-5g4data
GRAPHDB_QUERY_LIMIT=0
GRAPHDB_CONTEXT_LIMIT=10

# Package paths (overridden by package load for clones)
ENABLE_PACKAGE_LOAD=true
DOMAIN_PACKAGE_DIR=../SimulatorAgentPackages/5g4data-intent-mistral-small4-generating-agent
SKILL_FILE=../SimulatorAgentPackages/5g4data-intent-mistral-small4-generating-agent/skills/SKILL.md
SYSTEM_PROMPT_FILE=./SYSTEM_PROMPT.md
SHACL_SHAPES_FILE=../SimulatorAgentPackages/5g4data-intent-mistral-small4-generating-agent/validation/skill_subset_intent_shapes.ttl
SHACL_MAX_RETRIES=2
INTENT_REPORT_INTERVAL_MINUTES=10

# Optional MLflow tracing
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=
MLFLOW_TRACING_ENABLED=true
