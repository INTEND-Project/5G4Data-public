@prefix data5g: <http://5g4data.eu/5g4data#> .
@prefix icm: <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix log: <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix quan: <http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix imo: <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .

data5g:EXt1 a data5g:SampleExpectation ;
    icm:target data5g:t1 ;
    log:allOf data5g:COone .

data5g:COone a icm:Condition ;
    icm:valuesOfTargetProperty data5g:metricA_COone ;
    quan:unit "ms" .

data5g:oneSec a time:DurationDescription ;
    time:numericDuration "1"^^xsd:decimal ;
    time:unitType time:unitSecond .

data5g:EvOne a rdfs:Class ;
    rdfs:subClassOf imo:Event ;
    time:delay ( data5g:lastReportInstant data5g:oneSec ) .

data5g:REone a icm:ObservationReportingExpectation ;
    icm:target data5g:t1 ;
    icm:reportTriggers [ a rdfs:Container ;
            rdfs:member data5g:EvOne ] .

data5g:EXt2 a data5g:SampleExpectation ;
    icm:target data5g:t2 ;
    log:allOf data5g:COtwo .

data5g:COtwo a icm:Condition ;
    icm:valuesOfTargetProperty data5g:metricB_COtwo ;
    quan:unit "J" .

data5g:twoSec a time:DurationDescription ;
    time:numericDuration "2"^^xsd:decimal ;
    time:unitType time:unitSecond .

data5g:EvTwo a rdfs:Class ;
    rdfs:subClassOf imo:Event ;
    time:delay ( data5g:lastReportInstant data5g:twoSec ) .

data5g:REtwo a icm:ObservationReportingExpectation ;
    icm:target data5g:t2 ;
    icm:reportTriggers [ a rdfs:Container ;
            rdfs:member data5g:EvTwo ] .
