# Inbound A2A/API authentication (required in production)
AGENT_API_KEY=
AGENT_API_KEY_HEADER=X-Api-Key

# HTTP API server
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=3011

# A2A discovery
A2A_ENABLED=false
A2A_REGISTRY_BASE_URL=https://start5g-1.cs.uit.no/a2a-registry
A2A_AGENT_BASE_URL=http://localhost:3010
A2A_AGENT_CARD_PATH=/.well-known/agent-card.json
A2A_AUTO_REGISTER_ON_STARTUP=true

# LLM provider (set one)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0

# GraphDB HTTP Basic auth (required when GraphDB security is enabled)
GRAPHDB_USERNAME=telenor
GRAPHDB_PASSWORD=

# Package paths (overridden by package load for clones)
DOMAIN_PACKAGE_DIR=../SimulatorAgentPackages/5g4data-intent-generation
SKILL_FILE=../SimulatorAgentPackages/5g4data-intent-generation/skills/SKILL.md
SYSTEM_PROMPT_FILE=./SYSTEM_PROMPT.md
SHACL_SHAPES_FILE=../SimulatorAgentPackages/5g4data-intent-generation/validation/skill_subset_intent_shapes.ttl
