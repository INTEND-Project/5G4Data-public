{
  "forbiddenPhrases": [
    "<uuid4>",
    "<same-uuid4>",
    "<condition-id>",
    "i will proceed",
    "please hold on",
    "now i will create",
    "icm:ReportingExpectation",
    "data5g:TenMinuteReportEventDeployment a",
    "data5g:TenMinuteReportEventSustainability a",
    "data5g:TenMinuteReportEventNetwork a",
    "data5g:tenMinutesDeployment",
    "data5g:tenMinutesSustainability",
    "data5g:tenMinutesNetwork"
  ],
  "requiredTokens": [
    "icm:Intent",
    "icm:ObservationReportingExpectation",
    "imo:handler \"inServ\"",
    "imo:owner \"inChat\""
  ],
  "clarificationTag": "[deployment datacenter clarification required]",
  "conditionalRequirements": [
    {
      "intentFlag": "deployment",
      "requiresAnyTokens": ["data5g:DeploymentExpectation"],
      "error": "Deployment intent requires data5g:DeploymentExpectation."
    },
    {
      "intentFlag": "networkQos",
      "requiresAnyTokens": ["data5g:NetworkExpectation"],
      "error": "Network QoS intent requires data5g:NetworkExpectation."
    },
    {
      "intentFlag": "locality",
      "requiresAnyTokens": ["data5g:DataCenter", "data5g:appliesToRegion"],
      "error": "Locality intent requires data center or region grounding."
    },
    {
      "intentFlag": "sustainability",
      "requiresAnyTokens": ["data5g:SustainabilityExpectation"],
      "error": "Sustainability intent requires data5g:SustainabilityExpectation."
    },
    {
      "intentFlag": "reportToPrometheus",
      "requiresAnyTokens": ["data5g:prometheus"],
      "error": "Prometheus storage requested but reportDestinations missing data5g:prometheus."
    },
    {
      "intentFlag": "reportToGraphdb",
      "requiresAnyTokens": ["data5g:graphdb"],
      "error": "GraphDB storage requested but reportDestinations missing data5g:graphdb."
    },
    {
      "intentFlag": "coordination",
      "requiresAnyTokens": ["CoordinationExpectation"],
      "error": "Coordination requested but data5g:CoordinationExpectation missing."
    },
    {
      "intentFlag": "coordination",
      "requiresAnyTokens": ["ut:utility"],
      "error": "Coordination requested but ut:utility missing."
    },
    {
      "intentFlag": "coordination",
      "requiresAnyTokens": ["data5g:coordinates"],
      "error": "Coordination requested but data5g:coordinates missing."
    }
  ],
  "identifierRules": [
    {
      "regex": "\\bdata5g:(I|CO|CX|DE|NE|RE|RG|SE|CE)([A-Za-z0-9_-]+)\\b",
      "validateAsUuid4Suffix": true,
      "error": "Identifier local names must be UUIDv4-derived (32 hex, version=4, variant=8|9|a|b)."
    }
  ]
}
