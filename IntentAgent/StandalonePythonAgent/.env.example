STANDALONE_AGENT_LLM_LOG=

WORKLOAD_CATALOG_BASE_URL=https://start5g-1.cs.uit.no/wchartmuseum
GRAPHDB_ENDPOINT=https://start5g-1.cs.uit.no/graphdb/repositories/intents_and_intent_reports
GRAPHDB_NAMED_GRAPH=http://intendproject.eu/telenor/infra
GRAPHDB_QUERY_LIMIT=50
GRAPHDB_CONTEXT_LIMIT=10
DEFAULT_INTENT_HANDLER=inServ
DEFAULT_INTENT_OWNER=inChat
AUTO_GENERATE_DESCRIPTION=true

ONTOLOGY_ROOT=
EXAMPLE_INTENTS_ROOT=
