{
  "protocolVersion": "0.3.0",
  "name": "5g4data-intent-observation-generating-agent",
  "description": "Controls and reports observation behavior for created 5G4Data intents.",
  "domain": "telenor.5g4data",
  "url": "https://start5g-1.cs.uit.no/5g4data-intent-observation-generating-agent/v1",
  "version": "1.0.0",
  "capabilities": {
    "streaming": false,
    "pushNotifications": false,
    "stateTransitionHistory": true
  },
  "defaultInputModes": [
    "text/plain"
  ],
  "defaultOutputModes": [
    "text/plain",
    "application/json"
  ],
  "skills": [
    {
      "id": "observe-intent",
      "name": "Observe intent",
      "description": "Apply reporting controls and emit observation updates for an intent.",
      "tags": [
        "5g4data",
        "intent",
        "observation",
        "reporting"
      ],
      "inputModes": [
        "text/plain",
        "application/json"
      ],
      "outputModes": [
        "text/plain",
        "application/json"
      ]
    }
  ],
  "securitySchemes": {
    "agent-api-key": {
      "type": "apiKey",
      "in": "header",
      "name": "X-Api-Key",
      "description": "Shared service API key required for agent invocation and discovery."
    }
  },
  "security": [
    {
      "agent-api-key": []
    }
  ]
}
