# Example systemd unit for SimulatorController dev instance (next dev on port 3001).
# Install:
#   cp .env.dev.example .env.dev && edit secrets; npm run db:sync-from-prod
#   sudo cp scripts/systemd/simulator-controller-dev.service.example /etc/systemd/system/simulator-controller-dev.service
#   # Edit User, paths, and npm path if needed
#   sudo systemctl daemon-reload && sudo systemctl enable --now simulator-controller-dev
#
# Prod (simulator-controller.service) stays on port 3000 with next start; no build step for dev.

[Unit]
Description=SimulatorController dev (Next.js, port 3001)
After=network-online.target graphdb.service docker.service
Wants=network-online.target

[Service]
Type=simple
User=telco
WorkingDirectory=/home/telco/arneme/INTEND-Project/5G4Data-public/AgenticDataSimulator/SimulatorController
Environment=NODE_ENV=development
Environment=PATH=/home/telco/.nvm/versions/node/v20.20.2/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
EnvironmentFile=/home/telco/arneme/INTEND-Project/5G4Data-public/AgenticDataSimulator/SimulatorController/.env.dev
ExecStart=/home/telco/.nvm/versions/node/v20.20.2/bin/npm run dev:lab
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
