{
    email arne.munch-ellingsen@telenor.com
}

start5g-1.cs.uit.no {
    # Managed Agent routes for Workload-Catalog stack (non-tutorial)
    # Host ports:
    # - workload catalogue: 3040
    # - associated chartmuseum: 8080
    handle_path /wcatalog/* {
        reverse_proxy http://host.docker.internal:3040
    }

    handle_path /wchartmuseum/* {
        reverse_proxy http://host.docker.internal:8080
    }

    # OpenClaw Controller production (host port 3000)
    handle /tmf-simulator* {
        reverse_proxy http://host.docker.internal:3000 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # OpenClaw Controller dev (host port 3001)
    handle /tmf-simulator-dev* {
        reverse_proxy http://host.docker.internal:3001 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # OpenClaw agents (host ports; must match registry wellKnownURI paths)
    handle_path /5g4data-intent-generating-agent/* {
        reverse_proxy http://host.docker.internal:3011
    }

    handle_path /5g4data-intent-observation-generating-agent/* {
        reverse_proxy http://host.docker.internal:3012
    }

    # A2A Registry API (host port 17001; strip /a2a-registry prefix)
    handle /a2a-registry/api* {
        uri strip_prefix /a2a-registry
        reverse_proxy http://host.docker.internal:17001
    }

    # A2A Registry frontend (host port 17173)
    handle /a2a-registry* {
        uri strip_prefix /a2a-registry
        reverse_proxy http://host.docker.internal:17173
    }

    # ChartMuseum at /charts
    handle /charts/* {
        uri strip_prefix /charts
        reverse_proxy http://chartmuseum:8080
    }

    # Workload catalog legacy path
    handle /webapp/* {
        reverse_proxy http://webapp:3000
    }

    # Workload catalog at /workloads
    handle /workloads/* {
        uri replace /workloads /webapp
        reverse_proxy http://webapp:3000
    }

    # GraphDB on host port 7200 (OpenClaw agents use https://…/graphdb/…)
    handle /graphdb* {
        uri strip_prefix /graphdb
        reverse_proxy http://host.docker.internal:7200 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Prometheus UI/API (host port 9090)
    handle /prometheus* {
        uri strip_prefix /prometheus
        reverse_proxy http://host.docker.internal:9090 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Prometheus Pushgateway (host port 9091)
    handle /prometheus-pushgateway* {
        uri strip_prefix /prometheus-pushgateway
        reverse_proxy http://host.docker.internal:9091 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Grafana UI/API (host port 3002; subpath — do NOT strip_prefix)
    handle /grafana* {
        reverse_proxy http://host.docker.internal:3002 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # MLflow UI/API (host port 5000; subpath — do NOT strip_prefix)
    redir /mlflow /mlflow/ 308

    @mlflow path /mlflow /mlflow/*
    @mlflow_allowed {
        path /mlflow /mlflow/*
        remote_ip 85.165.67.213
    }

    handle @mlflow_allowed {
        reverse_proxy http://host.docker.internal:5000 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle @mlflow {
        respond "Forbidden" 403
    }

    # Main Flask app at root (must be last — catch-all)
    handle {
        reverse_proxy flask-app:5003
    }
}
