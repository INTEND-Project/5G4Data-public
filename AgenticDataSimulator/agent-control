#!/usr/bin/env bash
# Control OpenClaw simulator agents (intent generation + observations).
#
#   agent-control start    Load or start agent containers (reload clone when package or kernel changed).
#   agent-control stop     Stop and remove agent containers.
#   agent-control restart  Create missing agents, reload when package/kernel changed, or rebuild clone sources.
#   agent-control reload   Stop agents, remove all clones, package load from current sources (preserves API keys).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KERNEL="$ROOT/SimulatorAgentKernel"
PACKAGES="$ROOT/SimulatorAgentPackages"

AGENTS=(
  "5g4data-intent-generation|5g4data-intent-generating-agent|3011|5g4data-intent-generating-agent"
  "5g4data-intent-observations|5g4data-intent-observation-generating-agent|3012|5g4data-intent-observation-generating-agent"
)

# Paths copied from SimulatorAgentPackages into each clone (see packageCloneDeployer.ts).
DEPLOY_REL_PATHS=(
  manifest.json
  workflow.dsl.json
  compatibility.json
  checksums.txt
  rules
  validators
  tools
  prompts
  prompt_modules
  skills
  dependencies
  schemas
  validation
  examples
  tests
  mappings
  metadata
)

# Baseline kernel paths copied into each clone (see agentCloneManager.ts).
# Exclude package.json / package-lock.json: the clone merges package deps on load and
# would otherwise look newer than the baseline kernel without a real kernel change.
KERNEL_REL_PATHS=(
  src
  scripts
  Dockerfile
  .dockerignore
  tsconfig.json
)

usage() {
  cat <<EOF
Usage: agent-control {start|stop|restart|reload}

Run from the AgenticDataSimulator directory as ./agent-control,
or add AgenticDataSimulator/bin to PATH (see README.md).

  start    Create clones if missing; when package or SimulatorAgentKernel sources changed,
           remove existing clone(s), package load, and start containers.
  stop     Stop and remove running agent containers.
  restart  Like start for missing or package/kernel-changed agents; otherwise rebuild when clone sources changed.
  reload   Stop agents, remove all clone directories, package load both agents from current sources,
           and wait for health. Preserves AGENT_API_KEYS from SimulatorController/.env when present.
           Restart Controller and a2a-registry api/worker after reload (see scripts/restart-lab-from-source.sh).

Agents:
  - 5g4data-intent-generating-agent (port 3011)
  - 5g4data-intent-observation-generating-agent (port 3012)
EOF
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "ERROR: docker is not installed or not on PATH" >&2
    exit 1
  fi
  if ! docker compose version >/dev/null 2>&1; then
    echo "ERROR: docker compose is not available" >&2
    exit 1
  fi
}

clone_base_dir() {
  local suffix="$1"
  printf '%s/SimulatorAgentKernel-%s\n' "$ROOT" "$suffix"
}

find_clone_dir() {
  local suffix="$1"
  local base
  base="$(clone_base_dir "$suffix")"
  if [[ -d "$base" ]]; then
    printf '%s\n' "$base"
    return 0
  fi
  local latest=""
  local version=2
  while [[ -d "${base}-v${version}" ]]; do
    latest="${base}-v${version}"
    version=$((version + 1))
  done
  if [[ -n "$latest" ]]; then
    printf '%s\n' "$latest"
  fi
}

find_newest_file_epoch() {
  local path="$1"
  find "$path" \
    \( -path '*/node_modules/*' -o -path '*/logs/*' -o -path '*/dist/*' -o -path '*/.git/*' \) -prune \
    -o -type f -printf '%T@\n' 2>/dev/null \
    | sort -n \
    | tail -1 \
    | cut -d. -f1
}

newest_epoch_under_rel_paths() {
  local root="$1"
  shift
  local max=0
  local rel path epoch

  for rel in "$@"; do
    path="$root/$rel"
    [[ -e "$path" ]] || continue
    epoch="$(find_newest_file_epoch "$path" || true)"
    if [[ -n "$epoch" && "$epoch" -gt "$max" ]]; then
      max="$epoch"
    fi
  done

  if (( max > 0 )); then
    printf '%s\n' "$max"
  fi
}

newest_epoch_under_deploy_paths() {
  newest_epoch_under_rel_paths "$1" "${DEPLOY_REL_PATHS[@]}"
}

kernel_newest_epoch() {
  newest_epoch_under_rel_paths "$KERNEL" "${KERNEL_REL_PATHS[@]}"
}

clone_kernel_newest_epoch() {
  local clone_dir="$1"
  newest_epoch_under_rel_paths "$clone_dir" "${KERNEL_REL_PATHS[@]}"
}

needs_package_reload() {
  local package_dir="$1"
  local clone_dir="${2:-}"

  [[ -d "$package_dir" ]] || return 1
  [[ -n "$clone_dir" && -d "$clone_dir" ]] || return 1

  local package_epoch clone_epoch
  package_epoch="$(newest_epoch_under_deploy_paths "$package_dir" || true)"
  clone_epoch="$(newest_epoch_under_deploy_paths "$clone_dir" || true)"

  [[ -n "$package_epoch" ]] || return 1
  [[ -n "$clone_epoch" ]] || return 0

  (( package_epoch > clone_epoch ))
}

needs_kernel_reload() {
  local clone_dir="${1:-}"

  [[ -d "$KERNEL" ]] || return 1
  [[ -n "$clone_dir" && -d "$clone_dir" ]] || return 1

  local kernel_epoch clone_epoch
  kernel_epoch="$(kernel_newest_epoch || true)"
  clone_epoch="$(clone_kernel_newest_epoch "$clone_dir" || true)"

  [[ -n "$kernel_epoch" ]] || return 1
  [[ -n "$clone_epoch" ]] || return 0

  (( kernel_epoch > clone_epoch ))
}

needs_clone_reload() {
  local package_dir="$1"
  local clone_dir="${2:-}"

  needs_package_reload "$package_dir" "$clone_dir" && return 0
  needs_kernel_reload "$clone_dir" && return 0
  return 1
}

remove_clone_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0

  if [[ -f "$dir/docker-compose.yml" ]]; then
    echo "    Stopping container in ${dir} ..."
    (cd "$dir" && docker compose down --remove-orphans) || true
  fi

  echo "    Removing ${dir} ..."
  rm -rf "$dir" 2>/dev/null || true
  if [[ ! -d "$dir" ]]; then
    return 0
  fi

  # Container bind-mount writes under logs/ are often root-owned on the host.
  echo "    Clearing root-owned clone files via Docker ..."
  local parent name
  parent="$(cd "$(dirname "$dir")" && pwd)"
  name="$(basename "$dir")"
  if docker run --rm -v "${parent}:/parent" alpine:3.20 rm -rf "/parent/${name}"; then
    return 0
  fi

  echo "ERROR: could not remove ${dir} (permission denied)." >&2
  return 1
}

remove_all_clones_for_suffix() {
  local suffix="$1"
  local base dir version=2
  local -a dirs=()

  base="$(clone_base_dir "$suffix")"
  [[ -d "$base" ]] && dirs+=("$base")
  while [[ -d "${base}-v${version}" ]]; do
    dirs+=("${base}-v${version}")
    version=$((version + 1))
  done

  for dir in "${dirs[@]}"; do
    remove_clone_dir "$dir" || return 1
  done
}

CONTROLLER_ENV="${ROOT}/SimulatorController/.env"

read_preserved_agent_api_key() {
  local agent_name="$1"
  python3 - "$CONTROLLER_ENV" "$agent_name" <<'PY'
import json
import re
import sys

path, name = sys.argv[1], sys.argv[2]
try:
    text = open(path, encoding="utf-8").read()
except OSError:
    sys.exit(0)

match = re.search(r"^AGENT_API_KEYS=(.*)$", text, re.MULTILINE)
if not match:
    sys.exit(0)

raw = match.group(1).strip().strip("'\"")
try:
    data = json.loads(raw)
except json.JSONDecodeError:
    sys.exit(0)

key = (data.get(name) or "").strip()
if key:
    print(key)
PY
}

load_agent_package() {
  local package="$1"
  local label="$2"
  local agent_name="${3:-}"

  echo "==> Loading ${label} from package ${package}"
  if [[ ! -d "$KERNEL/node_modules" ]]; then
    echo "    Installing kernel dependencies ..."
    (cd "$KERNEL" && npm install)
  fi
  local preserve=""
  if [[ -n "$agent_name" ]]; then
    preserve="$(read_preserved_agent_api_key "$agent_name" || true)"
  fi
  if [[ -n "$preserve" ]]; then
    echo "    Preserving AGENT_API_KEY for ${agent_name} from SimulatorController/.env"
    (cd "$KERNEL" && PRESERVE_AGENT_API_KEY="$preserve" npx tsx src/index.ts package load "$PACKAGES/$package")
  else
    (cd "$KERNEL" && npx tsx src/index.ts package load "$PACKAGES/$package")
  fi
}

compose_image_created_epoch() {
  local clone_dir="$1"
  local image_id created
  image_id="$(cd "$clone_dir" && docker compose images -q agent 2>/dev/null | head -1)"
  if [[ -z "$image_id" ]]; then
    return 1
  fi
  created="$(docker inspect -f '{{.Created}}' "$image_id" 2>/dev/null || true)"
  if [[ -z "$created" ]]; then
    return 1
  fi
  date -d "$created" +%s 2>/dev/null || return 1
}

clone_newest_source_epoch() {
  local clone_dir="$1"
  find "$clone_dir" \
    \( -path "$clone_dir/node_modules" -o -path "$clone_dir/dist" -o -path "$clone_dir/logs" -o -path "$clone_dir/.git" \) -prune \
    -o -type f -printf '%T@\n' \
    | sort -n \
    | tail -1 \
    | cut -d. -f1
}

needs_image_build() {
  local clone_dir="$1"
  local image_epoch source_epoch

  if ! image_epoch="$(compose_image_created_epoch "$clone_dir")"; then
    return 0
  fi

  source_epoch="$(clone_newest_source_epoch "$clone_dir")"
  if [[ -z "$source_epoch" ]]; then
    return 1
  fi

  if (( source_epoch > image_epoch )); then
    return 0
  fi
  return 1
}

wait_for_health() {
  local port="$1"
  local label="$2"
  local url="http://127.0.0.1:${port}/health"
  echo "Waiting for ${label} at ${url} ..."
  for _ in $(seq 1 60); do
    if curl -sf "$url" >/dev/null 2>&1; then
      echo "OK: ${label} (${url})"
      return 0
    fi
    sleep 1
  done
  echo "ERROR: ${label} did not respond at ${url} within 60s" >&2
  return 1
}

start_agent() {
  local package="$1"
  local clone_suffix="$2"
  local port="$3"
  local label="$4"

  local package_dir="$PACKAGES/$package"
  local clone_dir
  clone_dir="$(find_clone_dir "$clone_suffix" || true)"

  if [[ -n "$clone_dir" ]] && needs_clone_reload "$package_dir" "$clone_dir"; then
    if needs_kernel_reload "$clone_dir"; then
      echo "==> SimulatorAgentKernel changed; reloading ${label}"
    else
      echo "==> Package ${package} changed; reloading ${label}"
    fi
    remove_all_clones_for_suffix "$clone_suffix"
    clone_dir=""
  fi

  if [[ -z "$clone_dir" || ! -f "$clone_dir/docker-compose.yml" ]]; then
    load_agent_package "$package" "$label" "$clone_suffix"
    clone_dir="$(find_clone_dir "$clone_suffix" || true)"
    if [[ -z "$clone_dir" ]]; then
      echo "ERROR: clone directory not found after package load for ${label}" >&2
      exit 1
    fi
  else
    echo "==> Starting ${label} in ${clone_dir}"
    if needs_image_build "$clone_dir"; then
      echo "    Build required (sources newer than image or image missing)"
      (cd "$clone_dir" && docker compose build)
    else
      echo "    Image up to date; skipping build"
    fi
    (cd "$clone_dir" && docker compose up -d)
  fi

  wait_for_health "$port" "$label"
  echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
  echo "Agent log files: ${clone_dir}/logs/"
  echo
}

restart_agent() {
  local package="$1"
  local clone_suffix="$2"
  local port="$3"
  local label="$4"

  local package_dir="$PACKAGES/$package"
  local clone_dir
  clone_dir="$(find_clone_dir "$clone_suffix" || true)"

  if [[ -z "$clone_dir" || ! -f "$clone_dir/docker-compose.yml" ]]; then
    echo "==> ${label}: not created yet; loading from package ${package}"
    start_agent "$package" "$clone_suffix" "$port" "$label"
    return 0
  fi

  if needs_clone_reload "$package_dir" "$clone_dir"; then
    if needs_kernel_reload "$clone_dir"; then
      echo "==> ${label}: SimulatorAgentKernel changed; reloading clone"
    else
      echo "==> ${label}: package ${package} changed; reloading clone"
    fi
    remove_all_clones_for_suffix "$clone_suffix"
    load_agent_package "$package" "$label" "$clone_suffix"
    clone_dir="$(find_clone_dir "$clone_suffix" || true)"
    if [[ -z "$clone_dir" ]]; then
      echo "ERROR: clone directory not found after package load for ${label}" >&2
      exit 1
    fi
    wait_for_health "$port" "$label"
    echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
    echo "Agent log files: ${clone_dir}/logs/"
    echo
    return 0
  fi

  if ! needs_image_build "$clone_dir"; then
    echo "==> ${label}: image up to date; skipping restart"
    return 1
  fi

  echo "==> Rebuilding and restarting ${label} in ${clone_dir}"
  (cd "$clone_dir" && docker compose build)
  (cd "$clone_dir" && docker compose up -d --force-recreate)
  wait_for_health "$port" "$label"
  echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
  echo "Agent log files: ${clone_dir}/logs/"
  echo
  return 0
}

stop_agent() {
  local clone_suffix="$1"
  local label="$2"

  local clone_dir
  clone_dir="$(find_clone_dir "$clone_suffix" || true)"

  if [[ -z "$clone_dir" ]]; then
    echo "==> ${label}: no clone directory found; nothing to stop"
    return 0
  fi
  if [[ ! -f "$clone_dir/docker-compose.yml" ]]; then
    echo "==> ${label}: no docker-compose.yml in ${clone_dir}; nothing to stop"
    return 0
  fi

  echo "==> Stopping ${label} in ${clone_dir}"
  (cd "$clone_dir" && docker compose down)
}

cmd_start() {
  require_docker
  echo "Starting OpenClaw simulator agents from ${ROOT}"
  echo

  local entry package clone_suffix port label
  for entry in "${AGENTS[@]}"; do
    IFS='|' read -r package clone_suffix port label <<<"$entry"
    start_agent "$package" "$clone_suffix" "$port" "$label"
  done

  echo "Both agents are up."
  echo "  Generation:    http://127.0.0.1:3011/health"
  echo "  Observations:  http://127.0.0.1:3012/health"
}

cmd_stop() {
  require_docker
  echo "Stopping OpenClaw simulator agents from ${ROOT}"
  echo

  local entry clone_suffix label
  for entry in "${AGENTS[@]}"; do
    IFS='|' read -r _ clone_suffix _ label <<<"$entry"
    stop_agent "$clone_suffix" "$label"
  done

  echo "Done."
}

cmd_restart() {
  require_docker
  echo "Checking OpenClaw simulator agents for package, kernel, or clone changes from ${ROOT}"
  echo

  local entry package clone_suffix port label updated=0
  for entry in "${AGENTS[@]}"; do
    IFS='|' read -r package clone_suffix port label <<<"$entry"
    if restart_agent "$package" "$clone_suffix" "$port" "$label"; then
      updated=$((updated + 1))
    fi
  done

  if (( updated == 0 )); then
    echo "No agents required creation or rebuild."
  else
    echo "Created or restarted ${updated} agent(s)."
    echo "  Generation:    http://127.0.0.1:3011/health"
    echo "  Observations:  http://127.0.0.1:3012/health"
  fi
}

cmd_reload() {
  require_docker
  echo "Force-reloading OpenClaw simulator agents from ${ROOT}"
  echo "    AGENT_API_KEYS preserved from SimulatorController/.env when present."

  cmd_stop
  echo

  local entry package clone_suffix port label
  for entry in "${AGENTS[@]}"; do
    IFS='|' read -r package clone_suffix port label <<<"$entry"
    echo "==> Force reload: ${label}"
    remove_all_clones_for_suffix "$clone_suffix"
    load_agent_package "$package" "$label" "$clone_suffix"
    wait_for_health "$port" "$label"
    local clone_dir
    clone_dir="$(find_clone_dir "$clone_suffix" || true)"
    if [[ -n "$clone_dir" ]]; then
      echo "Container logs: cd \"${clone_dir}\" && docker compose logs -f"
      echo "Agent log files: ${clone_dir}/logs/"
    fi
    echo
  done

  echo "Both agents reloaded from current package and kernel sources."
  echo "  Generation:    http://127.0.0.1:3011/health"
  echo "  Observations:  http://127.0.0.1:3012/health"
}

case "${1:-}" in
  start) cmd_start ;;
  stop) cmd_stop ;;
  restart) cmd_restart ;;
  reload) cmd_reload ;;
  -h|--help|help) usage ;;
  *)
    usage >&2
    exit 1
    ;;
esac
