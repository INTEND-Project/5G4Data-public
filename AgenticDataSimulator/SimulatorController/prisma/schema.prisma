generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String                @id @default(cuid())
  username     String                @unique
  passwordHash String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  sessions     Session[]
  scripts      Script[]
  kgTargets    KnowledgeGraphTarget[]
  runs         ScriptRun[]
  runLogs      ScriptRunLog[]
  intents      UserIntent[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Script {
  id          String         @id @default(cuid())
  userId      String
  domain      String
  name        String
  content     String
  shared      Boolean        @default(false)
  lastRunMode String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs        ScriptRun[]
  runLogs     ScriptRunLog[]
}

model KnowledgeGraphTarget {
  id           String      @id @default(cuid())
  userId       String
  domain       String
  repositoryId String
  graphIri     String
  displayName  String
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs         ScriptRun[]
}

model ScriptRun {
  id               String                @id @default(cuid())
  scriptId         String
  userId           String
  domain           String
  mode             String
  status           String
  graphTargetId    String?
  diagnosticsJson  Json?
  executionLogJson Json?
  createdAt        DateTime              @default(now())
  finishedAt       DateTime?
  script           Script                @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  graphTarget      KnowledgeGraphTarget? @relation(fields: [graphTargetId], references: [id], onDelete: SetNull)
}

model ScriptRunLog {
  id         String   @id @default(cuid())
  userId     String
  domain     String
  scriptName String
  scriptId   String?
  mode       String
  lines      Json
  startedAt  DateTime
  finishedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  script     Script?  @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  @@index([userId, domain, startedAt])
}

model UserIntent {
  id            String   @id @default(cuid())
  userId        String
  domain        String
  intentId      String
  storage       String?
  graphTargetId String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, intentId])
  @@index([userId, domain])
}
