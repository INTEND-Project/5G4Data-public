LLM_PROVIDER=openai

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=

STANDALONE_AGENT_HOST=127.0.0.1
STANDALONE_AGENT_PORT=8010
STANDALONE_AGENT_DEBUG=false
